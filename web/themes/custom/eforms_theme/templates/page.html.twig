{#
/**
 * @file
 * Oldalsablon — fejléc, tartalom, lábléc a Claude Design felület szerint.
 */
#}
<header class="topbar">
  <div class="wrap hdr">
    <a href="{{ path('<front>') }}" class="hdr-logo">
      <img src="{{ base_path ~ directory }}/images/logo.png" alt="Új Világ Nonprofit Szolgáltató Kft." />
    </a>
    <span class="hdr-title">eForms felkészítő szakmai tájékoztató nap · 2026</span>
    {% if has_eforms %}
      {% if show_back %}
        <a class="back" href="{{ path('eforms_event.page') }}"><i class="ri-arrow-left-line" aria-hidden="true"></i>Vissza az eseményoldalra</a>
      {% elseif reg_open %}
        <a class="dap-btn dap-btn--medium" href="{{ path('eforms_event.register') }}">Regisztráció</a>
      {% endif %}
    {% endif %}
  </div>
</header>

<main id="main-content" tabindex="-1">
  {% if grey_view %}
    <div class="grey-view">
      {{ page.content }}
    </div>
  {% else %}
    {{ page.content }}
  {% endif %}
</main>

{% if show_footer %}
  <footer>
    <div class="foot">
      <div>
        <p style="font-weight:700;color:#fff">eForms felkészítő szakmai tájékoztató nap · 2026</p>
        <p>Szervező: Új Világ Nonprofit Szolgáltató Kft.<br>Kérdés esetén: <a href="mailto:ekroktatas@ujvilag.gov.hu">ekroktatas@ujvilag.gov.hu</a></p>
      </div>
      <div class="foot-links">{% if has_eforms %}<a href="{{ path('eforms_event.teams_guide') }}">Teams csatlakozási segédlet</a><a href="{{ path('eforms_event.privacy') }}">Adatkezelési tájékoztató</a><a href="{{ path('eforms_event.imprint') }}">Impresszum</a>{% endif %}</div>
    </div>
  </footer>
{% endif %}
