<?php

/**
 * @file
 * eForms rendezvény-regisztráció — theme és mail hookok.
 */

/**
 * Implements hook_theme().
 */
function eforms_event_theme(array $existing, string $type, string $theme, string $path): array {
  return [
    'eforms_event_page' => [
      'variables' => [
        'occasions' => [],
        'program' => [],
        'speakers' => [],
        'contact_email' => '',
        'reg_open' => TRUE,
        'deadline_label' => '',
      ],
    ],
    'eforms_register_page' => [
      'variables' => [
        'form' => NULL,
        'deadline_label' => '',
      ],
    ],
    'eforms_register_closed' => [
      'variables' => [
        'deadline_label' => '',
        'contact_email' => '',
      ],
    ],
    'eforms_done' => [
      'variables' => [
        'reg' => [],
        'contact_email' => '',
      ],
    ],
    'eforms_privacy' => [
      'variables' => [
        'contact_email' => '',
      ],
    ],
    'eforms_imprint' => [
      'variables' => [
        'contact_email' => '',
      ],
    ],
  ];
}

/**
 * Implements hook_themes_installed().
 *
 * A blokkmodul témaváltáskor átmásolja az alapértelmezett téma összes
 * blokkját (cím, fülek, üzenetek, menük...) az új témába. A design letisztult
 * oldalszerkezetéhez csak a fő tartalom és az üzenetek blokkja kell — a
 * többit töröljük.
 */
function eforms_event_themes_installed(array $theme_list): void {
  if (!in_array('eforms_theme', $theme_list, TRUE)) {
    return;
  }
  $storage = \Drupal::entityTypeManager()->getStorage('block');
  $keep = ['eforms_theme_content', 'eforms_theme_messages'];
  foreach ($storage->loadByProperties(['theme' => 'eforms_theme']) as $block) {
    if (!in_array($block->id(), $keep, TRUE)) {
      $block->delete();
    }
  }
}

/**
 * Implements hook_cron().
 *
 * A határidő átlépésekor érvényteleníti a gyorsítótárazott nyilvános
 * oldalakat, hogy a lezárt állapot külső esemény nélkül is megjelenjen.
 */
function eforms_event_cron(): void {
  $open = \Drupal::service('eforms_event.capacity')->isOpen();
  $last = \Drupal::state()->get('eforms_event.reg_open');
  if ($last === NULL || (bool) $last !== $open) {
    \Drupal::state()->set('eforms_event.reg_open', $open);
    \Drupal\Core\Cache\Cache::invalidateTags(['config:eforms_event.settings']);
  }
}

/**
 * Implements hook_mail().
 *
 * Alkalmanként külön visszaigazoló levél (személyes / online), a
 * eforms_event.settings „emails” sablonjaiból. Helyettesítők:
 * @nev, @datum, @kapcsolat, @menetrend.
 */
function eforms_event_mail(string $key, array &$message, array $params): void {
  if ($key !== 'confirmation') {
    return;
  }
  $config = \Drupal::config('eforms_event.settings');
  $template = $config->get('emails.' . ($params['occasion'] ?? ''));

  $replacements = [
    '@nev' => $params['nev'] ?? '',
    '@datum' => $params['date_label'] ?? '',
    '@kapcsolat' => $config->get('contact_email') ?: '',
    '@menetrend' => \Drupal\Core\Url::fromRoute('eforms_event.page', [], ['absolute' => TRUE])->toString(),
  ];

  if ($template && !empty($template['body'])) {
    $message['subject'] = strtr($template['subject'] ?? 'Szakmai tájékoztató nap jelentkezés megerősítve', $replacements);
    foreach (explode("\n\n", trim(strtr($template['body'], $replacements))) as $paragraph) {
      $message['body'][] = $paragraph;
    }
    return;
  }

  // Tartalék általános szöveg, ha nincs sablon az adott alkalomhoz.
  $message['subject'] = 'Visszaigazolás — eForms felkészítő szakmai tájékoztató nap · 2026';
  $message['body'][] = 'Kedves ' . ($params['nev'] ?? '') . '!';
  $message['body'][] = 'Köszönjük, regisztrációját rögzítettük az eForms felkészítő szakmai tájékoztató napra.';
  $message['body'][] = 'Időpont: ' . ($params['date_label'] ?? '') . ' · ' . ($params['time_label'] ?? '');
  $message['body'][] = 'Részvétel módja: ' . ($params['mode'] ?? '');
  $message['body'][] = 'Kérdés esetén: ' . $replacements['@kapcsolat'];
}
